# Azure Cosmos DB Configuration
COSMOS_ENDPOINT=https://your-endpoint.documents.azure.com:443/
COSMOS_KEY=PrimaryKeyYourCosmosDBKeyHere
COSMOS_DB=your-database-name
COSMOS_CONTAINER=your-container-name

# Cohort Configuration (change per project)
# AI10 for msai10-attend
# AI9 for msai9-attend
# DT3 for msdata3-attend
# DT4 for msdata4-attend
COHORT_ID=AI10

# Security Configuration
TEACHER_PASSWORD=sample

# Flask Configuration
FLASK_ENV=production
PORT=8000
